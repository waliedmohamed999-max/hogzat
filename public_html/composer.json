{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-zip": "*",
        "cartalyst/sentinel": "^8.0",
        "doctrine/dbal": "^3.6",
        "eluceo/ical": "0.16.*",
        "guzzlehttp/guzzle": "^7.0",
        "glaivepro/hidevara": "1.1.0",
        "google/apiclient": "^2.0",
        "google/recaptcha": "^1.2",
        "gumlet/php-image-resize": "1.9.*",
        "jenssegers/agent": "^2.6",
        "johngrogg/ics-parser": "^2",
        "jorenvanhocht/laravel-share": "^4.1",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^2.8",
        "spatie/laravel-sitemap": "^7.0",
        "madnest/madzipper": "^1.0",
        "matthiasmullie/minify": "^1.3",
        "mavinoo/laravel-batch": "^2.2.3",
        "paypal/rest-api-sdk-php": "*",
        "phpmailer/phpmailer": "^6.1",
        "rachidlaasri/laravel-installer": "4.*",
        "rbdwllr/reallysimplejwt": "^2.0",
        "simplesoftwareio/simple-qrcode": "~4",
        "spatie/laravel-ignition": "^2.0",
        "stripe/stripe-php": "^10.0",
        "tedivm/jshrink": "~1.0",
        "tinify/tinify": "^1.5",
        "league/oauth2-facebook": "^2.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^10.0",
        "laravel/ui": "^4.0",
        "fakerphp/faker": "^1.22"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "AweCustom\\": "app/awe-custom/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ],
        "files": [
            "awebooking.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
